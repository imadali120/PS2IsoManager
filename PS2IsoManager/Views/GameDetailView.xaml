<UserControl x:Class="PS2IsoManager.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PS2IsoManager.Converters">

    <UserControl.Resources>
        <converters:ImagePathToSourceConverter x:Key="ImageConverter"/>
        <converters:MediaTypeToStringConverter x:Key="MediaTypeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVisConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- No selection placeholder -->
        <TextBlock Text="Select a game to view details"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#666688" FontSize="14" FontStyle="Italic"
                   Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>

        <!-- Detail panel -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolVisConverter}}">
            <StackPanel Margin="20">
                <!-- Cover art -->
                <Border Width="210" Height="300" Background="#0F3460" CornerRadius="6"
                        HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Grid>
                        <TextBlock Text="No Cover Art" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="#666688"
                                   FontSize="13"/>
                        <Image Source="{Binding SelectedGame.CoverPath, Converter={StaticResource ImageConverter}}"
                               Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,210,300" RadiusX="6" RadiusY="6"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Border>

                <!-- Game info -->
                <TextBlock Text="{Binding SelectedGame.DisplayName}"
                           FontSize="18" FontWeight="Bold" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,8"/>

                <Border Background="#16213E" CornerRadius="6" Padding="16" Margin="0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game ID:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGame.GameId}"
                                   FontFamily="Consolas" Margin="12,4" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Media:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedGame.Media, Converter={StaticResource MediaTypeConverter}}"
                                   Margin="12,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Parts:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGame.ChunkCount}" Margin="12,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="CRC32:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGame.CrcHex}"
                                   FontFamily="Consolas" Margin="12,4"/>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Content="Download Art" Command="{Binding DownloadArtCommand}" Margin="4"/>
                    <Button Content="Rename" Command="{Binding RenameGameCommand}" Margin="4"/>
                    <Button Content="Delete" Command="{Binding DeleteGameCommand}" Margin="4"
                            Background="#8B0000"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
