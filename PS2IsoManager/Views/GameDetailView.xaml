<UserControl x:Class="PS2IsoManager.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PS2IsoManager.Converters">

    <UserControl.Resources>
        <converters:MediaTypeToStringConverter x:Key="MediaTypeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVisConverter"/>

        <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <!-- Blurred cover art background -->
        <Image Source="{Binding SelectedGame.CoverImage}" Stretch="UniformToFill"
               Opacity="0.15" RenderOptions.BitmapScalingMode="LowQuality"
               VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image.Effect>
                <BlurEffect Radius="60"/>
            </Image.Effect>
        </Image>

        <!-- Gradient overlay to blend edges -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CC1A1A2E" Offset="0"/>
                    <GradientStop Color="#881A1A2E" Offset="0.3"/>
                    <GradientStop Color="#881A1A2E" Offset="0.7"/>
                    <GradientStop Color="#CC1A1A2E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- No selection placeholder -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}">
            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="#333355" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Select a game to view details"
                       HorizontalAlignment="Center"
                       Foreground="#666688" FontSize="14" FontStyle="Italic"/>
        </StackPanel>

        <!-- Detail panel -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasSelectedGame, Converter={StaticResource BoolVisConverter}}">
            <StackPanel x:Name="DetailContent" Margin="20">
                <!-- Cover art with glow effect -->
                <Border Width="210" Height="300" CornerRadius="6"
                        HorizontalAlignment="Center" Margin="0,10,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#E94560" Opacity="0.4" BlurRadius="24"
                                          ShadowDepth="0"/>
                    </Border.Effect>
                    <Border Background="#0F3460" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="No Cover Art" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#666688"
                                       FontSize="13"/>
                            <Image x:Name="CoverArtImage"
                                   Source="{Binding SelectedGame.CoverImage}"
                                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,210,300" RadiusX="6" RadiusY="6"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>
                </Border>

                <!-- Game info -->
                <TextBlock Text="{Binding SelectedGame.DisplayName}"
                           FontSize="18" FontWeight="Bold" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,8"/>

                <Border Background="#AA16213E" CornerRadius="6" Padding="16" Margin="0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game ID:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGame.GameId}"
                                   FontFamily="Consolas" Margin="12,4" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Media:" Foreground="#8888AA" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedGame.Media, Converter={StaticResource MediaTypeConverter}}"
                                   Margin="12,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Parts:" Foreground="#8888AA" Margin="0,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGame.ChunkCount}" Margin="12,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Format:" Foreground="#8888AA" Margin="0,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="ISO (direct)" Margin="12,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="CRC32:" Foreground="#8888AA" Margin="0,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedGame.CrcHex}"
                                   FontFamily="Consolas" Margin="12,4"
                                   Visibility="{Binding SelectedGame.IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Content="Download Art" Command="{Binding DownloadArtCommand}" Margin="4"/>
                    <Button Content="Rename" Command="{Binding RenameGameCommand}" Margin="4"/>
                    <Button Content="Delete" Command="{Binding DeleteGameCommand}" Margin="4"
                            Background="#8B0000"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
