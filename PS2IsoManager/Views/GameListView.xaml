<UserControl x:Class="PS2IsoManager.Views.GameListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PS2IsoManager.Converters">

    <UserControl.Resources>
        <converters:MediaTypeToStringConverter x:Key="MediaTypeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVisConverter"/>
    </UserControl.Resources>

    <ListBox ItemsSource="{Binding Games}"
             SelectedItem="{Binding SelectedGame}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover art thumbnail -->
                    <Border Grid.Column="0" Width="40" Height="52" CornerRadius="3"
                            Background="#0F3460" Margin="0,0,10,0" ClipToBounds="True">
                        <Grid>
                            <!-- Placeholder icon when no cover -->
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="#334466"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,40,52" RadiusX="3" RadiusY="3"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>

                    <!-- Media type badge -->
                    <Border Grid.Column="1" Background="#0F3460" CornerRadius="3"
                            Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Media, Converter={StaticResource MediaTypeConverter}}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#88AADD"/>
                    </Border>

                    <!-- Game name + ID -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding GameId}" FontSize="11" Foreground="#8888AA"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Chunk count (ul.cfg games) -->
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="10,0"
                               Foreground="#8888AA" FontSize="12"
                               Visibility="{Binding IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}">
                        <Run Text="{Binding ChunkCount, Mode=OneWay}"/>
                        <Run Text=" parts"/>
                    </TextBlock>

                    <!-- ISO badge (direct ISO games) -->
                    <TextBlock Grid.Column="3" Text="ISO" VerticalAlignment="Center" Margin="10,0"
                               Foreground="#88AADD" FontSize="12" FontWeight="SemiBold"
                               Visibility="{Binding IsDirectIso, Converter={StaticResource BoolVisConverter}}"/>

                    <!-- CRC (only for ul.cfg games) -->
                    <TextBlock Grid.Column="4" Text="{Binding CrcHex}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="#666688" FontFamily="Consolas"
                               Margin="0,0,4,0"
                               Visibility="{Binding IsDirectIso, Converter={StaticResource BoolVisConverter}, ConverterParameter=Invert}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
