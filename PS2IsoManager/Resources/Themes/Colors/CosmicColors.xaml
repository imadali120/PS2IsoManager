<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core Colors -->
    <Color x:Key="BackgroundColor">#0D0221</Color>
    <Color x:Key="PanelColor">#150533</Color>
    <Color x:Key="AccentColor">#1A0A3E</Color>
    <Color x:Key="HighlightColor">#00E5FF</Color>
    <Color x:Key="TextColor">#E8E0FF</Color>
    <Color x:Key="TextDimColor">#9B8EC4</Color>
    <Color x:Key="BorderColor">#2D1B69</Color>

    <!-- Core Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Extended Brushes -->
    <SolidColorBrush x:Key="AccentTextBrush" Color="#80F0FF"/>
    <SolidColorBrush x:Key="TextVeryDimBrush" Color="#6B5B95"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#3D2A6E"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E0A46"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF1744"/>
    <SolidColorBrush x:Key="PanelTranslucentBrush" Color="#AA150533"/>
    <SolidColorBrush x:Key="ChromeTextBrush" Color="#B0A0E0"/>
    <SolidColorBrush x:Key="HighlightPressedBrush" Color="#00B8D4"/>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#11FFFFFF"/>
    <SolidColorBrush x:Key="HighlightTintBrush" Color="#3300E5FF"/>

    <!-- Composite Brushes -->
    <LinearGradientBrush x:Key="BackgroundOverlayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#CC0D0221" Offset="0"/>
        <GradientStop Color="#880D0221" Offset="0.3"/>
        <GradientStop Color="#880D0221" Offset="0.7"/>
        <GradientStop Color="#CC0D0221" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
