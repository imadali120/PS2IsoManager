<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core Colors -->
    <Color x:Key="BackgroundColor">#F0F1F3</Color>
    <Color x:Key="PanelColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#E0E5EC</Color>
    <Color x:Key="HighlightColor">#2563EB</Color>
    <Color x:Key="TextColor">#1A1A1A</Color>
    <Color x:Key="TextDimColor">#6B7280</Color>
    <Color x:Key="BorderColor">#D1D5DB</Color>

    <!-- Core Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Extended Brushes -->
    <SolidColorBrush x:Key="AccentTextBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="TextVeryDimBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#B0B8C4"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="PanelTranslucentBrush" Color="#AAFFFFFF"/>
    <SolidColorBrush x:Key="ChromeTextBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="HighlightPressedBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="#15000000"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#11000000"/>
    <SolidColorBrush x:Key="HighlightTintBrush" Color="#332563EB"/>

    <!-- Composite Brushes -->
    <LinearGradientBrush x:Key="BackgroundOverlayBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#CCF0F1F3" Offset="0"/>
        <GradientStop Color="#88F0F1F3" Offset="0.3"/>
        <GradientStop Color="#88F0F1F3" Offset="0.7"/>
        <GradientStop Color="#CCF0F1F3" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
