<Window x:Class="PS2IsoManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PS2IsoManager.ViewModels"
        xmlns:views="clr-namespace:PS2IsoManager.Views"
        xmlns:converters="clr-namespace:PS2IsoManager.Converters"
        Title="PS2 ISO Manager"
        Icon="app-icon.ico"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVisConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteGameCommand}"/>
        <KeyBinding Key="F2" Command="{Binding RenameGameCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding AddGameCommand}"/>
    </Window.InputBindings>

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="12,0">
                        <Ellipse Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource HighlightColor}" Offset="0.3"/>
                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0.5"/>
                                    <GradientStop Color="{DynamicResource PanelColor}" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="PS2 ISO Manager" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                        <Button Content="&#xE921;" Click="MinimizeButton_Click"
                                Style="{DynamicResource ChromeButton}" ToolTip="Minimize"/>
                        <Button x:Name="MaxButton" Content="&#xE922;" Click="MaximizeButton_Click"
                                Style="{DynamicResource ChromeButton}" ToolTip="Maximize"/>
                        <Button Content="&#xE8BB;" Click="CloseButton_Click"
                                Style="{DynamicResource ChromeCloseButton}" ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" Padding="8,6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Select Folder" Command="{Binding SelectFolderCommand}"
                            Margin="0,0,6,0" ToolTip="Select USB drive or OPL folder"/>
                    <Button Content="Add Game (Ctrl+A)" Command="{Binding AddGameCommand}"
                            Margin="0,0,6,0" ToolTip="Add a PS2 ISO"/>
                    <Button Content="Refresh (F5)" Command="{Binding RefreshCommand}"
                            Margin="0,0,6,0"/>

                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,2"/>

                    <Button Content="Download All Art" Command="{Binding DownloadAllArtCommand}"
                            Margin="6,0,0,0"/>

                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,2"/>

                    <!-- Theme picker -->
                    <Button x:Name="ThemeButton" Content="Theme" Margin="6,0,0,0"
                            Background="{DynamicResource SurfaceBrush}"
                            Click="ThemeButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="ThemeMenu">
                                <MenuItem Header="OPL Dark" Click="ThemeMenuItem_Click" Tag="OplDark"/>
                                <MenuItem Header="Midnight" Click="ThemeMenuItem_Click" Tag="Midnight"/>
                                <MenuItem Header="Light" Click="ThemeMenuItem_Click" Tag="Light"/>
                                <MenuItem Header="Cosmic" Click="ThemeMenuItem_Click" Tag="Cosmic"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasUsbPath, Converter={StaticResource BoolVisConverter}}">
                        <TextBlock Text="{Binding UsbPath}" Foreground="{DynamicResource AccentTextBrush}" FontSize="12"
                                   FontFamily="Consolas" MaxWidth="500" TextTrimming="CharacterEllipsis"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="300"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*" MinWidth="260" MaxWidth="380"/>
                </Grid.ColumnDefinitions>

                <views:GameListView Grid.Column="0" DataContext="{Binding}"/>

                <GridSplitter Grid.Column="1" Width="3" Background="{DynamicResource BorderBrush}"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <views:GameDetailView Grid.Column="2" DataContext="{Binding}"/>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" CornerRadius="0,0,8,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource TextDimBrush}" MaxWidth="500"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <!-- DVD count -->
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="6,2" Margin="4,0">
                            <TextBlock FontSize="11" Foreground="{DynamicResource AccentTextBrush}">
                                <Run Text="DVD "/>
                                <Run Text="{Binding DvdCount, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <!-- CD count -->
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="6,2" Margin="4,0">
                            <TextBlock FontSize="11" Foreground="{DynamicResource AccentTextBrush}">
                                <Run Text="CD "/>
                                <Run Text="{Binding CdCount, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <!-- Separator -->
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,4"/>

                        <!-- Total size -->
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="6,2" Margin="4,0">
                            <TextBlock FontSize="11" Foreground="{DynamicResource AccentTextBrush}">
                                <Run Text="{Binding EstimatedSize, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <!-- Separator -->
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,4"/>

                        <!-- Game count -->
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextVeryDimBrush}" VerticalAlignment="Center"
                                   Margin="4,0,0,0">
                            <Run Text="{Binding Games.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text=" game(s)"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
